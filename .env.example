# Application Configuration
ENVIRONMENT=production
LOG_LEVEL=info
VERSION=2.0.0

# Machine IDs for Snowflake ID generation (must be unique per replica: 0-1023)
# For docker-compose scale, set different IDs manually or use orchestration
MACHINE_ID=1

# PostgreSQL Configuration
POSTGRES_DB=urlshortener
POSTGRES_USER=urlshortener
POSTGRES_PASSWORD=change-me-in-production
POSTGRES_PRIMARY_HOST=postgres-primary
POSTGRES_PRIMARY_PORT=5432
POSTGRES_REPLICA_HOSTS=postgres-replica1,postgres-replica2
POSTGRES_SSLMODE=disable

# PostgreSQL Replication
REPLICATION_USER=replicator
REPLICATION_PASSWORD=repl-change-me-in-production

# Redis Cluster Configuration
REDIS_CLUSTER_ADDRS=redis-master1:6379,redis-master2:6379,redis-master3:6379

# Server Configuration
SERVER_PORT=8080
APP_HOST=localhost

# Docker Compose Scaling
APP_REPLICAS=4
